<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane maxHeight="600.0" maxWidth="800.0" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.CompanyManagementController">
   <top>
      <AnchorPane prefHeight="151.0" prefWidth="800.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblTitre" alignment="CENTER" layoutX="151.0" layoutY="14.0" prefHeight="27.0" prefWidth="648.0" styleClass="label24B" text="Label" />
            <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/agence.png" />
               </image>
            </ImageView>
            <TextField fx:id="txfSelection" layoutX="511.0" layoutY="87.0" prefHeight="25.0" prefWidth="275.0" promptText="Rechercher..." />
            <ImageView fx:id="imvSelection" fitHeight="57.0" fitWidth="50.0" layoutX="453.0" layoutY="87.0" onMouseClicked="#evtOnMouseClickedImvSelection" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/loupe.png" />
               </image>
            </ImageView>
         </children>
      </AnchorPane>
   </top>
   <bottom>
      <ButtonBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <buttons>
            <Button fx:id="btnSupprimer" mnemonicParsing="false" onMouseClicked="#evtOnMouseClickedBtnSupprimer" styleClass="btnGrey" text="Supprimer" />
            <Button fx:id="btnModifier" maxWidth="120.0" minWidth="120.0" mnemonicParsing="false" onMouseClicked="#evtOnMouseClickedBtnModifier" prefWidth="120.0" styleClass="btn" text="Modifier" />
            <Button fx:id="btnAjouter" mnemonicParsing="false" onMouseClicked="#evtOnMouseClickedBtnAjouter" styleClass="btnGreen" text="Ajouter" />
          <Button fx:id="btnAnnuler" mnemonicParsing="false" onMouseClicked="#evtOnMouseClickedBtnAnnuler" styleClass="btnAnnuler" text="Annuler" />
        </buttons>
         <BorderPane.margin>
            <Insets right="20.0" />
         </BorderPane.margin>
      </ButtonBar>
   </bottom>
   <center>
      <TableView fx:id="tbvDonnees" onMousePressed="#evtOnMousePressedTbvDonnees" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="tbcCompanyName" maxWidth="220.0" minWidth="220.0" prefWidth="220.0" text="Nom de l'agence" />
          <TableColumn fx:id="tbcCompanyTelephone" maxWidth="100.0" minWidth="100.0" prefWidth="100.0" text="Téléphone" />
            <TableColumn fx:id="tbcCompanyEmail" prefWidth="75.0" text="\@ email" />
            <TableColumn fx:id="tbcCompanyAddress" prefWidth="75.0" text="Adresse" />
            <TableColumn fx:id="tbcCompanyTown" prefWidth="75.0" text="Ville" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </center>
   <stylesheets>
      <URL value="@../style/application.css" />
      <URL value="@../style/tableViews.css" />
   </stylesheets>
</BorderPane>
