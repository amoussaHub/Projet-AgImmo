<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeTableColumn?>
<?import javafx.scene.control.TreeTableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane maxHeight="800.0" maxWidth="1000.0" prefHeight="800.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TownManagementController">
   <top>
      <AnchorPane prefHeight="151.0" prefWidth="800.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblTitre" alignment="CENTER" layoutX="152.0" layoutY="14.0" prefHeight="27.0" prefWidth="698.0" styleClass="label24B" text="Label" />
            <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/agence.png" />
               </image>
            </ImageView>
            <TextField fx:id="txfSelection" layoutX="511.0" layoutY="87.0" prefHeight="25.0" prefWidth="275.0" promptText="Rechercher..." visible="false" />
            <ImageView fx:id="imvSelection" fitHeight="150.0" fitWidth="50.0" layoutX="453.0" layoutY="87.0" onMouseClicked="#evtOnMouseClickedImvSelection" pickOnBounds="true" preserveRatio="true" visible="false">
               <image>
                  <Image url="@../images/loupe.png" />
               </image>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </ImageView>
            <ImageView fitHeight="150.0" fitWidth="200.0" layoutX="849.0" layoutY="1.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/towns.png" />
               </image>
            </ImageView>
         </children>
      </AnchorPane>
   </top>
   <bottom>
      <ButtonBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <buttons>
            <Button fx:id="btnSupprimer" mnemonicParsing="false" onMouseClicked="#evtOnMouseClickedBtnSupprimer" styleClass="btnGrey" text="Supprimer" />
            <Button fx:id="btnModifier" maxWidth="120.0" minWidth="120.0" mnemonicParsing="false" onMouseClicked="#evtOnMouseClickedBtnModifier" prefWidth="120.0" styleClass="btn" text="Modifier" />
            <Button fx:id="btnAjouter" mnemonicParsing="false" onMouseClicked="#evtOnMouseClickedBtnAjouter" styleClass="btnGreen" text="Ajouter" />
          <Button fx:id="btnAnnuler" mnemonicParsing="false" onMouseClicked="#evtOnMouseClickedBtnAnnuler" styleClass="btnAnnuler" text="Annuler" />
        </buttons>
         <BorderPane.margin>
            <Insets right="20.0" />
         </BorderPane.margin>
      </ButtonBar>
   </bottom>
   <stylesheets>
      <URL value="@../style/application.css" />
      <URL value="@../style/tableViews.css" />
   </stylesheets>
   <center>
      <TreeTableView fx:id="ttvVilles" onMousePressed="#evtOnMousePressedTbvDonnees" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TreeTableColumn fx:id="ttcVille" prefWidth="75.0" text="Ville" />
          <TreeTableColumn fx:id="ttcCodePostal" prefWidth="75.0" text="Code postal" />
        </columns>
         <columnResizePolicy>
            <TreeTableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TreeTableView>
   </center>
</BorderPane>
