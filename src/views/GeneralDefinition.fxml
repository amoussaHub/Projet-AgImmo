<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="700.0" stylesheets="@../style/application.css" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.FeuxDefinitionController">
   <bottom>
      <ButtonBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <buttons>
          <Button fx:id="btnValider" mnemonicParsing="false" onMouseClicked="#evtOnMouseClickedBtnValider" styleClass="btn" text="Valider" />
            <Button fx:id="btnAnnuler" mnemonicParsing="false" onMouseClicked="#evtOnMouseClickedBtnAnnuler" prefHeight="31.0" prefWidth="150.0" styleClass="btnAnnuler" text="Annuler" />
        </buttons>
         <BorderPane.margin>
            <Insets right="20.0" />
         </BorderPane.margin>
      </ButtonBar>
   </bottom>
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
         <children>
            <AnchorPane prefHeight="322.0" prefWidth="700.0" />
            <TitledPane animated="false" collapsible="false">
               <content>
                  <TextArea fx:id="txaMsgErreur" prefHeight="120.0" prefWidth="200.0" styleClass="messageErreur" />
               </content>
            </TitledPane>
         </children>
      </VBox>
   </center>
   <top>
      <AnchorPane prefHeight="146.0" prefWidth="700.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblTitre" layoutX="350.0" layoutY="60.0" styleClass="label24B" text="Label" />
            <ImageView fitHeight="150.0" fitWidth="200.0" layoutY="-2.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/agence.png" />
               </image>
            </ImageView>
         </children>
      </AnchorPane>
   </top>
</BorderPane>
